{
  // ================================================================
  // OpenClaw Light 配置文件
  // 复制为 openclaw.json 并填入你的值
  // 格式：JSON5（支持注释和尾随逗号）
  // 敏感信息通过 ${ENV_VAR} 从环境变量注入
  // 详细说明见 docs/zh/guides/configuration.md
  // ================================================================

  // --- LLM 提供商 ---
  // 可选值: "anthropic" | "deepseek" | "groq" | "glm" | "openai" | 自定义
  "provider": "anthropic",
  "model": "claude-sonnet-4-5-20250929",

  // 自定义提供商覆盖（使用内置提供商时无需配置）
  // "providerConfig": {
  //   "baseUrl": "https://my-proxy.example.com/v1",
  //   "apiKeyEnv": "MY_CUSTOM_API_KEY",
  //   "maxTokens": 4096
  // },

  // --- 认证 ---
  // "api_key"（默认，使用环境变量中的 API Key）
  // "oauth"（Anthropic OAuth 2.0 PKCE，在 Telegram 中用 /auth 命令授权）
  // "auth": {
  //   "mode": "oauth",
  //   "clientId": "9d1c250a-e61b-44d9-88ed-5944d1962f5e",
  //   "tokenFile": "./auth_tokens.json"
  // },

  // --- 通道 ---
  "channels": {
    "telegram": {
      "botToken": "${TELEGRAM_BOT_TOKEN}",
      "allowedUsers": []  // Telegram 用户 ID 数组，空 = 不限制
    },
    // 飞书/Lark Channel（WebSocket 长连接，无需公网 URL）
    // "feishu": {
    //   "appId": "${FEISHU_APP_ID}",
    //   "appSecret": "${FEISHU_APP_SECRET}",
    //   "domain": "https://open.feishu.cn",  // 国际版: "https://open.larksuite.com"
    //   "allowedUsers": []  // open_id 白名单，空 = 不限制
    // },
    // HTTP API 通道（默认关闭）
    // 启用后访问 http://<device>:8080/ 即可打开 Web Chat 页面
    // "httpApi": {
    //   "enabled": true,
    //   "listen": "0.0.0.0:8080",
    //   "authToken": "${HTTP_AUTH_TOKEN}"  // 可选 Bearer Token 认证，空/未设置 = 无认证
    // },
    // CLI 交互通道（默认关闭，适合本地调试）
    // "cli": {
    //   "enabled": true
    // }
  },

  // --- 语音 ---
  "messages": {
    // 响应前缀模板（可选），支持 {model}、{provider}、{thinkingLevel} 变量
    // "responsePrefix": "[{model}] ",
    "tts": {
      // 自动语音: "inbound"(语音回语音) | "always" | "tagged"(<speak>标签) | 其他值=关闭
      "auto": "inbound",
      // TTS 提供商: "edge"(免费默认) | "volcengine"/"doubao" | "openai" | "elevenlabs"
      "provider": "edge",
      "maxTextLength": 500,
      // Edge TTS（免费，无需 API Key）
      "edge": {
        "voice": "zh-CN-XiaoxiaoNeural",  // zh-CN-YunxiNeural(男声)
        "rate": "+10%"
        // "chromiumVersion": "143.0.3650.75"  // Edge TTS 403 时更新此版本号
      }
      // OpenAI TTS
      // "openai": {
      //   "apiKeyEnv": "OPENAI_API_KEY",
      //   "model": "tts-1",         // "tts-1" | "tts-1-hd"
      //   "voice": "alloy"          // "alloy" | "echo" | "nova" | "shimmer"
      // },
      // ElevenLabs TTS
      // "elevenlabs": {
      //   "apiKeyEnv": "ELEVENLABS_API_KEY",
      //   "modelId": "eleven_multilingual_v2",
      //   "voiceId": "你的Voice ID"  // 从 elevenlabs.io 控制台获取
      // },
      // 火山引擎（豆包）TTS — 原生 OGG/Opus 输出，中文效果优秀
      // "volcengine": {
      //   "appId": "你的应用ID",
      //   "accessToken": "${VOLCENGINE_ACCESS_TOKEN}",
      //   "cluster": "volcano_tts",
      //   "voiceType": "zh_female_vv_uranus_bigtts"  // 从控制台音色列表获取
      //   // "speedRatio": 1.0,
      //   // "volumeRatio": 1.0,
      //   // "pitchRatio": 1.0
      // }
    },
    "mediaUnderstanding": {
      "audio": {
        // STT 提供商: "groq"(Whisper) | "doubao"/"volcengine"(火山引擎) | "google"(Google Cloud)
        "provider": "groq",
        "model": "whisper-large-v3-turbo"
        // 自托管 Whisper: "baseUrl": "https://my-whisper-server/v1"

        // 火山引擎（豆包）STT 配置（provider 设为 "doubao" 或 "volcengine" 时使用）
        // "volcengine": {
        //   "appId": "你的应用ID",
        //   "accessToken": "${VOLCENGINE_ACCESS_TOKEN}",
        //   "cluster": "volc.bigasr.sauc.duration"
        // }

        // Google Cloud STT（provider 设为 "google" 时使用）
        // "google": {
        //   "languageCode": "zh-CN"  // BCP-47 语言代码
        // }
      }
    }
  },

  // --- 工具白名单 ---
  "tools": {
    "allow": [
      "web_fetch",          // 网页抓取（SSRF 防护）
      "web_search",         // 网页搜索（DuckDuckGo/Brave）
      "get_time",           // 获取当前时间
      "cron",               // 定时任务
      "memory",             // 长期记忆
      "exec",               // Shell 命令执行
      "sessions_spawn",     // 启动子 Agent
      "sessions_list",      // 列出子 Agent
      "sessions_history",   // 获取子 Agent 结果
      "sessions_send",      // 向子 Agent 发消息
      "backup",             // 备份管理（状态/开启/关闭/立即备份）
      "file_read",          // 文件读取（带行号，二进制检测，64KB 截断）
      "file_write",         // 文件写入（自动创建父目录）
      "file_edit",          // 文件编辑（精确字符串替换）
      "file_find"           // 文件搜索（按文件名/内容搜索）
      // "ha_control"       // Home Assistant 控制（需配置 homeAssistant）
    ]
  },

  // --- Home Assistant（可选）---
  "homeAssistant": {
    "url": "http://192.168.1.100:8123",
    "token": "${HA_TOKEN}"
  },

  // --- Agent 配置 ---
  "agents": {
    // 系统提示词（默认已包含工具规则、安全规则、记忆指引，一般不需要改）
    // "systemPrompt": "你是一个中文助手...",
    "agentTimeoutSecs": 900,       // Agent 单轮超时（秒）
    "thinking": "off",             // 扩展思考: "off" | "low" | "medium" | "high"（仅 Claude）
    "compactRatio": 0.4,           // 压缩比（保留 40% 消息）
    "followupDebounceMs": 2000,    // 追加消息防抖（毫秒）
    // 队列模式: "interrupt"(新消息中断当前执行) | "queue"(排队等待)
    "queueMode": "interrupt",
    // 上下文文件（启动时加载到系统提示词，SOUL.md 等价）
    // "contextFiles": ["./SOUL.md"],
    // 备选模型（主模型失败时按顺序尝试）
    // "fallbackModels": [
    //   { "provider": "deepseek", "model": "deepseek-chat", "apiKeyEnv": "DEEPSEEK_API_KEY" },
    //   { "provider": "groq", "model": "llama-3.3-70b-versatile", "apiKeyEnv": "GROQ_API_KEY", "baseUrl": "https://api.groq.com/openai/v1" }
    // ]
  },

  // --- 会话持久化 ---
  "session": {
    "dir": "./sessions",       // 不要修改（与 docker-compose volume 对应）
    "historyLimit": 0,         // 原始消息上限（0=不限）
    "dmHistoryLimit": 20       // 用户轮次上限（20 轮对话历史）
  },

  // --- 长期记忆 ---
  "memory": {
    "dir": "./memory",         // 不要修改（与 docker-compose volume 对应）
    "maxMemoryBytes": 4096,    // MEMORY.md 大小上限
    "maxContextBytes": 4096    // 注入系统提示的记忆上下文上限
  },

  // --- 网页抓取 ---
  // "webFetch": {
  //   "maxDownloadBytes": 2000000  // 下载体积上限（字节），默认 2MB
  // },

  // --- 网页搜索 ---
  "webSearch": {
    "provider": "duckduckgo",  // "duckduckgo"(免费) | "brave"(需 API Key)
    "maxResults": 5
    // Brave 搜索: "apiKeyEnv": "BRAVE_SEARCH_API_KEY"
  },

  // --- Shell 执行 ---
  "exec": {
    "timeoutSecs": 30,         // 命令超时（最大 300）
    "maxOutputBytes": 8192,    // 输出截断上限
    "skillsDir": "./skills"    // 技能脚本目录（不要修改）
  },

  // --- 自动备份 ---
  // "backup": {
  //   "enabled": true,         // 总开关（默认 true）
  //   "dir": "./backups",      // 存储目录
  //   "intervalHours": 24,     // 最小间隔（小时）
  //   "retentionDays": 7,      // 保留天数
  //   "maxSizeMb": 200         // 备份总大小上限（MB），超过从最旧删除
  // }

  // --- MCP 外部工具服务器（可选）---
  // "mcp": {
  //   "servers": {
  //     "filesystem": {
  //       "command": "npx",
  //       "args": ["-y", "@modelcontextprotocol/server-filesystem", "/data"],
  //       "timeoutSecs": 60,
  //       "maxOutputBytes": 65536
  //     }
  //   }
  // }
}
